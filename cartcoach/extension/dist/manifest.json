{
  "manifest_version": 3,
  "name": "CartCoach — Smart Spending Guardrail",
  "version": "1.0.0",
  "description": "Real-time financial nudges at checkout. Think twice before you buy.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.target.com/*",
    "https://*.sephora.com/*",
    "https://*.bestbuy.com/*",
    "https://*.walmart.com/*",
    "https://*.etsy.com/*",
    "http://localhost:8000/*",
    "http://localhost/*",
    "file:///*"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.target.com/*",
        "https://*.sephora.com/*",
        "https://*.bestbuy.com/*",
        "https://*.walmart.com/*",
        "https://*.etsy.com/*",
        "http://localhost/*",
        "file:///*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["onboarding/index.html", "dashboard/index.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
